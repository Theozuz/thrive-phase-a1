# Normalise line endings to LF in the repository, regardless of OS.
# Working-tree files on Windows can still be CRLF; the hash function
# normalises before hashing so this is belt-and-braces.
* text=auto eol=lf

# Shell scripts must be LF (won't run otherwise on Unix)
*.sh text eol=lf

# Python should be LF for consistency
*.py text eol=lf

# YAML / JSON / Markdown — text, LF
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf